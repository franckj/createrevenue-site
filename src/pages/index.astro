---
import BaseLayout from '../layouts/BaseLayout.astro';

const challenges = [
  'You struggle to forecast revenue reliably.',
  'Your sales team is underperforming or lacks industry experience.',
  'Customers ghost you, delay decisions, or fail to commit.',
  'Your value proposition fails to resonate.',
  "You're not getting consistent, repeatable quarter-over-quarter revenue growth.",
  'Your pilots and proof-of-concept engagements are floundering.',
];
---

<BaseLayout
  title="Home"
  description="B2B sales coaching for health tech startups and investors. Accelerate revenue, win better customers, and reduce sales risk."
>
  <!-- Hero -->
  <section class="hero">
    <div class="container">
      <div class="hero__content">
        <p class="hero__eyebrow">B2B Sales Expert for <span class="text-highlight-underline">Health Tech</span> Startups &amp; Investors</p>
        <h1 class="hero__title">
          I help health tech companies
          <span class="text-highlight">accelerate</span> revenue,
          <span class="text-highlight">win</span> better customers,
          and <span class="text-highlight">reduce</span> sales risk.
        </h1>
        <div class="hero__actions">
          <a href="/contact/" class="btn btn--primary btn--large">Let's Chat</a>
          <a href="/services/" class="btn btn--outline btn--large">How I Help</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Social proof -->
  <section class="logos section--gray">
    <div class="container text-center">
      <p class="logos__label">Trusted by teams backed by</p>
      <div class="logos__grid">
        <span class="logos__item">ObservSMART</span>
        <span class="logos__item">TEDCO</span>
        <span class="logos__item">Health Tech Co.</span>
        <span class="logos__item">MedStart</span>
      </div>
    </div>
  </section>

  <!-- Challenges -->
  <section class="section challenges">
    <div class="container">
      <h2 class="text-center mb-2xl">Do These Sales Challenges<br />Sound Familiar?</h2>
      <div class="challenges__grid">
        {challenges.map(challenge => (
          <div class="challenges__item">
            <span class="challenges__icon" aria-hidden="true">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
                <circle cx="12" cy="12" r="10" />
                <line x1="15" y1="9" x2="9" y2="15" />
                <line x1="9" y1="9" x2="15" y2="15" />
              </svg>
            </span>
            <p>{challenge}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- How I Help -->
  <section class="section section--dark how-i-help">
    <div class="container">
      <h2 class="text-center mb-2xl">How I Help</h2>
      <div class="services-preview">
        <div class="service-card">
          <div class="service-card__icon">🎯</div>
          <h3>Sales Call Tune-Up</h3>
          <p>Real-time coaching on your actual sales calls. I observe, diagnose, and help you close the gaps that cost you deals.</p>
        </div>
        <div class="service-card">
          <div class="service-card__icon">📈</div>
          <h3>Revenue Strategy</h3>
          <p>Build a repeatable sales process that produces predictable revenue. From pipeline to close, we fix what's broken.</p>
        </div>
        <div class="service-card">
          <div class="service-card__icon">🧭</div>
          <h3>Executive Coaching</h3>
          <p>For founders and sales leaders who need a seasoned advisor in their corner. Confidential, direct, results-focused.</p>
        </div>
      </div>
      <div class="text-center mt-2xl">
        <a href="/services/" class="btn btn--primary btn--large">Explore Services</a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section cta-section">
    <div class="container text-center">
      <h2>Ready to Fix Your Sales?</h2>
      <p class="cta-section__sub">Book a free 30-minute call. No pitch, just a conversation about where you're stuck and how to move forward.</p>
      <a href="/contact/" class="btn btn--primary btn--large mt-lg">Let's Talk</a>
    </div>
  </section>
</BaseLayout>

<style>
  /* Hero */
  .hero {
    background: var(--color-navy);
    color: var(--color-white);
    padding: var(--space-5xl) 0;
    position: relative;
    overflow: hidden;
  }

  .hero::before {
    content: '';
    position: absolute;
    top: -50%;
    right: -20%;
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(0, 201, 167, 0.08) 0%, transparent 70%);
    pointer-events: none;
  }

  .hero__content {
    max-width: 740px;
    position: relative;
  }

  .hero__eyebrow {
    font-size: 1rem;
    font-weight: 500;
    color: var(--color-gray-300);
    margin-bottom: var(--space-lg);
  }

  .hero__title {
    color: var(--color-white);
    font-size: clamp(2.2rem, 5vw, 3.2rem);
    line-height: 1.15;
    margin-bottom: var(--space-2xl);
  }

  .hero__actions {
    display: flex;
    gap: var(--space-md);
    flex-wrap: wrap;
  }

  /* Logos */
  .logos {
    padding: var(--space-2xl) 0;
  }

  .logos__label {
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-gray-400);
    margin-bottom: var(--space-lg);
  }

  .logos__grid {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-3xl);
    flex-wrap: wrap;
  }

  .logos__item {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.1rem;
    color: var(--color-gray-300);
    opacity: 0.6;
  }

  /* Challenges */
  .challenges__grid {
    max-width: 680px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .challenges__item {
    display: flex;
    align-items: flex-start;
    gap: var(--space-md);
  }

  .challenges__icon {
    flex-shrink: 0;
    color: var(--color-coral);
    margin-top: 2px;
  }

  .challenges__item p {
    font-size: 1.05rem;
    margin: 0;
    color: var(--color-gray-600);
  }

  /* Services preview */
  .services-preview {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-xl);
  }

  .service-card {
    background: var(--color-navy-light);
    border: 1px solid var(--color-slate);
    border-radius: 10px;
    padding: var(--space-2xl);
    transition: all var(--transition-base);
  }

  .service-card:hover {
    border-color: var(--color-teal);
    transform: translateY(-3px);
    box-shadow: 0 8px 30px rgba(0, 201, 167, 0.1);
  }

  .service-card__icon {
    font-size: 1.8rem;
    margin-bottom: var(--space-md);
  }

  .service-card h3 {
    color: var(--color-white);
    margin-bottom: var(--space-sm);
  }

  .service-card p {
    color: var(--color-gray-300);
    font-size: 0.95rem;
    line-height: 1.6;
    margin: 0;
  }

  /* CTA Section */
  .cta-section {
    background: var(--color-gray-50);
  }

  .cta-section__sub {
    font-size: 1.15rem;
    color: var(--color-gray-500);
    max-width: 500px;
    margin: var(--space-md) auto 0;
  }

  @media (max-width: 768px) {
    .hero {
      padding: var(--space-3xl) 0;
    }

    .services-preview {
      grid-template-columns: 1fr;
    }

    .hero__actions {
      flex-direction: column;
    }
  }
</style>
