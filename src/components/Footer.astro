---
const currentYear = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container">
    <div class="footer__grid">
      <div class="footer__brand">
        <span class="footer__logo">create<span class="footer__logo-accent">revenue</span></span>
        <p class="footer__tagline">B2B sales coaching for health tech companies that want to accelerate revenue, win better customers, and reduce sales risk.</p>
      </div>

      <div class="footer__nav">
        <h4 class="footer__heading">Navigate</h4>
        <ul role="list">
          <li><a href="/about/">About</a></li>
          <li><a href="/services/">Services</a></li>
          <li><a href="/blog/">Blog</a></li>
          <li><a href="/contact/">Contact</a></li>
        </ul>
      </div>

      <div class="footer__nav">
        <h4 class="footer__heading">Connect</h4>
        <ul role="list">
          <li><a href="https://www.linkedin.com/in/brendanmcadams/" target="_blank" rel="noopener">LinkedIn</a></li>
          <li><a href="/rss.xml">RSS Feed</a></li>
        </ul>
      </div>
    </div>

    <div class="footer__bottom">
      <p>&copy; {currentYear} Create Revenue. All rights reserved.</p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--color-navy);
    color: var(--color-gray-300);
    padding: var(--space-4xl) 0 var(--space-xl);
  }

  .footer__grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: var(--space-3xl);
  }

  .footer__logo {
    font-family: var(--font-display);
    font-size: 1.3rem;
    font-weight: 800;
    letter-spacing: -0.03em;
    color: var(--color-white);
    display: block;
    margin-bottom: var(--space-md);
  }

  .footer__logo-accent {
    color: var(--color-teal);
  }

  .footer__tagline {
    font-size: 0.9rem;
    line-height: 1.6;
    max-width: 320px;
  }

  .footer__heading {
    color: var(--color-white);
    font-family: var(--font-display);
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: var(--space-md);
  }

  .footer__nav ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .footer__nav a {
    color: var(--color-gray-300);
    font-size: 0.9rem;
    transition: color var(--transition-fast);
  }

  .footer__nav a:hover {
    color: var(--color-teal);
  }

  .footer__bottom {
    margin-top: var(--space-3xl);
    padding-top: var(--space-xl);
    border-top: 1px solid var(--color-slate);
    font-size: 0.85rem;
    color: var(--color-gray-400);
  }

  @media (max-width: 768px) {
    .footer__grid {
      grid-template-columns: 1fr;
      gap: var(--space-2xl);
    }
  }
</style>
